# Copy this file to .env.local for local Expo development.
# Keep real secrets out of git.

# Convex
# Created by `npx convex dev`; required for Convex CLI commands such as codegen/dev.
CONVEX_DEPLOYMENT=
# Public Convex deployment URL used by the Expo app and embedded into builds.
# Example: https://your-deployment.eu-west-1.convex.cloud
EXPO_PUBLIC_CONVEX_URL=

# Clerk
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=
EXPO_PUBLIC_CLERK_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_CLERK_GOOGLE_ANDROID_CLIENT_ID=

# Ingestion / admin review
# Set these in Convex environment variables for deployed Convex functions.
# They are listed here so local/dev setup is discoverable.
DDISCOVER_INGESTION_TOKEN=
DDISCOVER_ADMIN_EMAILS=

# n8n workflow runtime variables.
# Set these in n8n Cloud/self-hosted n8n, not in the mobile app build.
DDISCOVER_CONVEX_SITE_URL=
DDISCOVER_N8N_SOURCES_JSON=
DDISCOVER_GOOGLE_PLACES_QUERIES_JSON=
OPENAI_API_KEY=
DDISCOVER_OPENAI_MODEL=gpt-4.1-mini
GOOGLE_PLACES_API_KEY=

# Optional scraper tuning for Convex imports.
DDISCOVER_GEOCODE_DELAY_MS=1100
DDISCOVER_IMAGE_DELAY_MS=200
DDISCOVER_IMAGE_MAX_BYTES=5242880

# Optional local Android helper script settings.
DDISCOVER_ANDROID_AVD=ddiscover_dev_device
DDISCOVER_ANDROID_EMULATOR_ARGS=
DDISCOVER_ADB_TIMEOUT_MS=15000
EXPO_DEV_SERVER_PORT=8081
