# Copy this file to `.env` on the Raspberry Pi.
# Do not commit the real `.env`; it is ignored by git.

# Container versions
N8N_IMAGE_TAG=latest

# PostgreSQL
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=replace-with-a-long-random-password

# n8n core
# Generate with: openssl rand -hex 32
N8N_ENCRYPTION_KEY=replace-with-a-64-character-hex-key
GENERIC_TIMEZONE=Europe/Berlin
TZ=Europe/Berlin

# Local network access.
# Use the Pi hostname or LAN IP while testing, for example raspberrypi.local.
N8N_BIND_ADDRESS=0.0.0.0
N8N_PORT=5678
N8N_HOST=raspberrypi.local
N8N_PROTOCOL=http
N8N_EDITOR_BASE_URL=http://raspberrypi.local:5678
N8N_WEBHOOK_URL=http://raspberrypi.local:5678/
N8N_SECURE_COOKIE=false
N8N_DIAGNOSTICS_ENABLED=false
N8N_BLOCK_ENV_ACCESS_IN_NODE=false

# DDiscover Convex ingestion target.
# Use the Convex site URL, not the convex.cloud app URL.
DDISCOVER_CONVEX_SITE_URL=https://your-convex-deployment.convex.site
DDISCOVER_INGESTION_TOKEN=replace-with-the-same-token-configured-in-convex

# OpenAI / LLM extraction workflow.
OPENAI_API_KEY=
DDISCOVER_OPENAI_MODEL=gpt-4.1-mini
DDISCOVER_N8N_SOURCES_JSON=[{"sourceKey":"objekt-klein-a-events","name":"Objekt klein a events","sourceType":"calendar_page","url":"https://objektkleina.com/events"}]

# Google Places bootstrap workflow.
GOOGLE_PLACES_API_KEY=
DDISCOVER_GOOGLE_PLACES_QUERIES_JSON=["night club in Dresden Germany","bar with live music in Dresden Germany","event venue nightlife Dresden Germany"]
